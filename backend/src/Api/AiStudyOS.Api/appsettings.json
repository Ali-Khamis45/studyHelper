{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Jwt": {
    "SigningKey": "",
    "Issuer": "AiStudyOS",
    "Audience": "AiStudyOS",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 21
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "MaximumLength": 128
  },
  "RateLimiting": {
    "PermitLimit": 20,
    "WindowSeconds": 60
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "DefaultModel": "llama3.1",
    "TimeoutSeconds": 120
  },
  "Planner": {
    "RecentHistoryDays": 7,
    "WeekViewDays": 7
  }
}
