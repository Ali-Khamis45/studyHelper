# --- Database ---
# Host port 5433 (not 5432) to avoid clashing with other local Postgres instances.
POSTGRES_DB=aistudyos
POSTGRES_USER=aistudyos
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433
DB_CONNECTION_STRING=Host=localhost;Port=5433;Database=aistudyos;Username=aistudyos;Password=changeme

# --- Redis ---
REDIS_CONNECTION_STRING=localhost:6379

# --- Auth ---
JWT_SIGNING_KEY=replace-with-a-long-random-secret
JWT_ISSUER=AiStudyOS
JWT_AUDIENCE=AiStudyOS
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI Providers ---
# OpenAI and Ollama are exercised in Phase 1. Anthropic/Gemini adapters compile
# and are DI-registered but are left untested until keys are supplied.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
